{
    "packageManager": "pnpm",
    "testRunner": "vitest",
    "checkers": ["typescript"],
    "plugins": [
        "@stryker-mutator/vitest-runner",
        "@stryker-mutator/typescript-checker"
    ],
    "mutate": [
        "src/utils/**/*.ts",
        "src/hooks/**/*.ts",
        "src/use-cases/**/*.ts",
        "src/services/**/*.ts",
        "!src/**/*.test.ts",
        "!src/**/*.test.tsx",
        "!src/**/*.spec.ts",
        "!src/**/*.spec.tsx",
        "!src/**/*.d.ts"
    ],
    "reporters": ["html", "clear-text", "progress"],
    "coverageAnalysis": "off"
}