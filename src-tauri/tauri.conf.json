{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "kavynex",
    "version": "1.1.1",
    "identifier": "com.kavynex.app",
    "build": {
        "beforeDevCommand": "pnpm dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "pnpm build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "kavynex",
                "width": 800,
                "height": 600,
                "dragDropEnabled": true
            }
        ],
        "security": {
            "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: https: data: blob:; media-src 'self' asset: blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:",
            "devCsp": "default-src 'self' ipc: http://ipc.localhost http://localhost:1420; connect-src 'self' ipc: http://ipc.localhost http://localhost:1420 ws://localhost:1420; img-src 'self' asset: https: data: blob:; media-src 'self' asset: blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:",
            "assetProtocol": {
                "enable": true,
                "scope": [
                    "**/*"
                ]
            }
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "createUpdaterArtifacts": true,
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    },
    "plugins": {
        "updater": {
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIyNzFEMkI5QTQ2MUM0MUYKUldRZnhHR2t1ZEp4SXZXMmtURHdpK0lMcXBEVHdWOUJmQkNaV1VIVmpBRjQzVjlqRGVPdkhtMmgK",
            "endpoints": [
                "https://github.com/eduardoghi/kavynex/releases/latest/download/latest.json"
            ],
            "windows": {
                "installMode": "passive"
            }
        }
    }
}