<assembly xmlns="urn:schemas-microsoft-com:asm.v1" manifestVersion="1.0">
  <dependency>
    <dependentAssembly>
      <assemblyIdentity
        type="win32"
        name="Microsoft.Windows.Common-Controls"
        version="6.0.0.0"
        processorArchitecture="*"
        publicKeyToken="6595b64144ccf1df"
        language="*"
      />
    </dependentAssembly>
  </dependency>
  <!--
    Opt the process into long paths so Win32 file APIs (which std::fs calls) are not capped at
    the legacy 260-char MAX_PATH for normal, non-"\\?\" paths. This only takes effect when the
    machine also has LongPathsEnabled=1 in the registry, so it is the "belt"; the code in
    services/library_paths.rs additionally rewrites library paths to their "\\?\" form, which
    bypasses MAX_PATH unconditionally and is what actually closes the gap on machines without
    the registry setting.
  -->
  <application xmlns="urn:schemas-microsoft-com:asm.v3">
    <windowsSettings>
      <longPathAware xmlns="http://schemas.microsoft.com/SMI/2016/WindowsSettings">true</longPathAware>
    </windowsSettings>
  </application>
</assembly>
