{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "dialog:allow-open",

    "fs:allow-mkdir",
    "fs:allow-write-text-file",
    "fs:allow-read-file",
    "fs:allow-exists",
    "fs:allow-read-dir",
    "fs:allow-remove",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "$APPDATA/live_chat"
        },
        {
          "path": "$APPDATA/live_chat/*"
        },
        {
          "path": "$APPDATA/live_chat/**"
        }
      ]
    }
  ]
}
