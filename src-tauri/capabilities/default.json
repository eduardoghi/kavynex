{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:allow-open-url",
    "opener:allow-default-urls",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",

    "process:allow-restart"
  ]
}
